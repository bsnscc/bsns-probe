    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@bsns/probe-core": "workspace:*",
    "node-html-parser": "^7.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.19.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.6"
  }
}
